datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
  MICROSOFT
}

enum Role {
  SUPER_ADMIN
  BUSINESS_OWNER
}

model User {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  email          String       @unique
  passwordHash   String?
  name           String
  role           Role         @default(BUSINESS_OWNER)
  provider       AuthProvider @default(LOCAL)
  googleId       String?      @unique
  appleId        String?      @unique
  microsoftId    String?      @unique
  profilePicture String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  // Relations
  businessGroups BusinessGroup[]
}

model BusinessGroup {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  ownerId         String   @db.ObjectId
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Wizard Onboarding progress tracking
  setupStep       Int      @default(1) // Current step (1-6)
  isSetupComplete Boolean  @default(false)

  // Step 1: Business Information
  description     String?
  yearStarted     Int?
  logoUrl         String?
  coverImageUrl   String?

  // Step 2: Contact Information
  mobileNumber    String?
  whatsAppNumber  String?
  email           String?
  website         String?
  supportEmail    String?

  // Step 3: Address
  country         String?
  state           String?
  city            String?
  areaLocality    String?
  address         String?
  pinCode         String?
  googleMapsLink  String?

  // Relations
  locations       Location[]
  subscriptions   Subscription[]
  documents       BusinessDocument[]
  services        BusinessService[]
  products        BusinessProduct[]
  paymentMethods  BusinessPaymentMethod[]
  languages       BusinessLanguage[]
  websiteConfig   Website?
}

model BusinessService {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  businessGroupId String        @db.ObjectId
  businessGroup   BusinessGroup @relation(fields: [businessGroupId], references: [id], onDelete: Cascade)
  name            String
  createdAt       DateTime      @default(now())
}

model BusinessProduct {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  businessGroupId String        @db.ObjectId
  businessGroup   BusinessGroup @relation(fields: [businessGroupId], references: [id], onDelete: Cascade)
  name            String
  createdAt       DateTime      @default(now())
}

model BusinessPaymentMethod {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  businessGroupId String        @db.ObjectId
  businessGroup   BusinessGroup @relation(fields: [businessGroupId], references: [id], onDelete: Cascade)
  methodName      String
  createdAt       DateTime      @default(now())
}

model BusinessLanguage {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  businessGroupId String        @db.ObjectId
  businessGroup   BusinessGroup @relation(fields: [businessGroupId], references: [id], onDelete: Cascade)
  language        String
  createdAt       DateTime      @default(now())
}

model BusinessDocument {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  businessGroupId String        @db.ObjectId
  businessGroup   BusinessGroup @relation(fields: [businessGroupId], references: [id], onDelete: Cascade)
  type            String        // e.g. "GST", "UDYAM", "FSSAI", "SHOP_LICENSE"
  value           String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([businessGroupId, type])
}

enum SubscriptionTier {
  FREE
  STARTER
  GROWTH
  PREMIUM
  AGENCY
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

model Subscription {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId
  businessGroupId String             @db.ObjectId
  businessGroup   BusinessGroup      @relation(fields: [businessGroupId], references: [id], onDelete: Cascade)
  tier            SubscriptionTier   @default(FREE)
  status          SubscriptionStatus @default(ACTIVE)
  expiresAt       DateTime?
  locationLimit   Int                @default(1)
  websiteLimit    Int                @default(1)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model Location {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  businessGroupId String        @db.ObjectId
  businessGroup   BusinessGroup @relation(fields: [businessGroupId], references: [id], onDelete: Cascade)
  name            String
  address         String?
  city            String?
  country         String?
  phone           String?
  category        String?
  hours           Json?         // Operating hours
  socialLinks     Json?         // Social links
  xp              Int           @default(0)
  level           Int           @default(1)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  reviews           Review[]
  taskProgress      TaskProgress[]
  customers         Customer[]
  reviewCampaigns   ReviewCampaign[]
  qrs               ReviewQRCode[]
  landingPage       ReviewLandingPage?
}

enum TaskCategory {
  PROFILE
  ACTIVITY
  TRUST
  REVIEWS
  WEBSITE
  PHOTOS
}

model Task {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  xpReward    Int
  category    TaskCategory
  triggerCondition String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  progress    TaskProgress[]
}

model TaskProgress {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  locationId  String    @db.ObjectId
  location    Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  taskId      String    @db.ObjectId
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([locationId, taskId])
}

enum ReviewSource {
  GOOGLE
  INTERNAL
  WEBSITE
  FACEBOOK
  MANUAL
}

enum ReviewStatus {
  NEW
  OPEN
  REPLIED
  RESOLVED
  ARCHIVED
}

enum ReviewChannel {
  QR
  SMS
  WHATSAPP
  EMAIL
  DIRECT_LINK
  NFC
}

model Review {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  locationId      String       @db.ObjectId
  location        Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  source          ReviewSource @default(INTERNAL)
  sourceReviewId  String?      @unique // External ID (e.g. from Google API)
  rating          Int          // 1 to 5
  
  // Existing fields for backward compatibility
  authorName      String       // Reviewer name
  comment         String?      // Review text
  replyText       String?      // Owner response text
  repliedAt       DateTime?    // Response timestamp
  
  // New CRM & Workflow tracking
  reviewerPhoto   String?
  status          ReviewStatus @default(NEW)
  sentiment       String?      // POSITIVE, NEUTRAL, NEGATIVE
  priority        String       @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assignedTo      String?
  followUpDate    DateTime?
  internalNotes   String?
  tags            String[]
  metadata        Json?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ReplyTemplate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  ratingMatch Int?     // Match specific ratings (e.g. only 5-star reviews)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Website {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  businessGroupId String           @db.ObjectId @unique
  businessGroup   BusinessGroup    @relation(fields: [businessGroupId], references: [id], onDelete: Cascade)
  
  subdomain       String           @unique
  customDomain    String?          @unique
  isPublished     Boolean          @default(false)
  
  // Settings & Theme
  theme           String           @default("default") // default, modern, elegant
  primaryColor    String           @default("#1976d2")
  secondaryColor  String           @default("#9c27b0")
  font            String           @default("Outfit")
  
  // SEO configuration
  metaTitle       String?
  metaDescription String?
  keywords        String?
  ogImage         String?

  // Analytics Configurations (Placeholders only)
  googleAnalyticsId   String?
  searchConsoleId     String?
  metaPixelId         String?
  clarityId           String?

  // Relations
  sections        WebsiteSection[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model WebsiteSection {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  websiteId    String   @db.ObjectId
  website      Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  
  type         String   // e.g. HERO, ABOUT, SERVICES, PRODUCTS, GALLERY, REVIEWS, CONTACT, FAQ, CTA, FOOTER
  enabled      Boolean  @default(true)
  displayOrder Int      @default(0)
  settings     Json     // Config parameters for specific section (e.g. title alignments, background colors)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([websiteId, type])
}

model Customer {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  locationId      String          @db.ObjectId
  location        Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name            String
  email           String?
  phone           String?
  notes           String?
  pipeline        String          @default("LEAD") // LEAD, CONTACTED, CONVERTED, LOST
  
  // Relations
  reviewRequests  ReviewRequest[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ReviewCampaign {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  locationId      String          @db.ObjectId
  location        Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  isActive        Boolean         @default(true)
  
  // Cached Metrics (updated dynamically)
  totalSent       Int             @default(0)
  totalOpened     Int             @default(0)
  totalCompleted  Int             @default(0)
  conversionRate  Float           @default(0.0)
  averageRating   Float           @default(0.0)

  // Relations
  requests        ReviewRequest[]
  qrCodes         ReviewQRCode[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ReviewRequest {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  campaignId      String          @db.ObjectId
  campaign        ReviewCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId      String          @db.ObjectId
  customer        Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  channel         ReviewChannel   @default(EMAIL)
  status          String          @default("PENDING") // PENDING, SENT, OPENED, COMPLETED, FAILED
  
  // Journey Timestamps
  sentAt          DateTime?
  openedAt        DateTime?
  ratedAt         DateTime?
  redirectedAt    DateTime?
  completedAt     DateTime?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ReviewQRCode {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  locationId      String          @db.ObjectId
  location        Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  campaignId      String?         @db.ObjectId
  campaign        ReviewCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  uniqueQrId      String          @unique
  name            String          // e.g. "Counter QR", "Table 4"
  type            String          // COUNTER, TABLE, INVOICE, DIGITAL, VISITING_CARD, STANDEE
  qrTypeClass     String          @default("STATIC") // STATIC, DYNAMIC
  scanCounter     Int             @default(0)
  lastScan        DateTime?
  createdBy       String          // User ID
  isActive        Boolean         @default(true)
  expiryDate      DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ReviewLandingPage {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  locationId      String        @db.ObjectId @unique
  location        Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  logoUrl         String?
  welcomeMessage  String        @default("How was your experience with us?")
  ratingThreshold Int           @default(4)
  googleReviewUrl String?
  facebookReviewUrl String?
  thankYouMessage String        @default("Thank you for your feedback!")
  buttonText      String        @default("Write a Review")
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
